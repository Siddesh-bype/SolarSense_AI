# SolarSense AI — Environment Variables
# Copy this file to .env and fill in the values

# Anthropic API key for LLM report generation (optional — templated fallback used if absent)
ANTHROPIC_API_KEY=

# Redis URL (optional — synchronous mode used if absent)
REDIS_URL=redis://localhost:6379

# PVGIS offline mode (set to true if PVGIS API is unreachable)
PVGIS_OFFLINE_MODE=true

# Server configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
